{
  "name": "@rc-component/pagination",
  "version": "1.4.0",
  "description": "pagination ui component for react",
  "keywords": [
    "react",
    "react-component",
    "react-pagination",
    "pagination",
    "antd",
    "pager"
  ],
  "main": "./lib/index",
  "module": "./es/index",
  "types": "./es/index.d.ts",
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./assets/*": "./assets/*",
    "./locale/*": {
      "types": "./es/locale/*.d.ts",
      "import": "./es/locale/*.js",
      "require": "./lib/locale/*.js"
    },
    "./lib/locale/*": {
      "types": "./es/locale/*.d.ts",
      "import": "./es/locale/*.js",
      "require": "./lib/locale/*.js"
    },
    "./es/locale/*": {
      "types": "./es/locale/*.d.ts",
      "import": "./es/locale/*.js",
      "require": "./lib/locale/*.js"
    }
  },
  "files": [
    "assets/*.css",
    "assets/*.less",
    "es",
    "lib"
  ],
  "homepage": "https://react-component.github.io/pagination",
  "repository": {
    "type": "git",
    "url": "https://github.com/react-component/pagination.git"
  },
  "bugs": {
    "url": "https://github.com/react-component/pagination/issues"
  },
  "license": "MIT",
  "scripts": {
    "start": "dumi dev",
    "build": "npm run docs:build",
    "docs:build": "dumi build",
    "docs:deploy": "gh-pages -d docs-dist",
    "gh-pages": "cross-env GH_PAGES=1 npm run docs:build && npm run docs:deploy",
    "compile": "father build && lessc assets/index.less assets/index.css",
    "prepublishOnly": "npm run compile && rc-np",
    "lint": "eslint src/ --ext .ts,.tsx,.jsx,.js,.md",
    "prettier": "prettier --write --ignore-unknown .",
    "test": "rc-test",
    "coverage": "rc-test --coverage",
    "prepare": "husky",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@rc-component/util": "^1.11.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@rc-component/father-plugin": "^2.2.0",
    "@rc-component/np": "^1.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "14.5.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@umijs/fabric": "^4.0.1",
    "cross-env": "^10.1.0",
    "dumi": "^2.4.35",
    "eslint": "^10.6.0",
    "father": "^4.6.23",
    "gh-pages": "^6.3.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "less": "^4.6.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.0",
    "@rc-component/select": "^1.8.0",
    "rc-test": "^7.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0"
  },
  "cnpm": {
    "mode": "npm"
  },
  "tnpm": {
    "mode": "npm"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "publishConfig": {
    "access": "public"
  }
}
