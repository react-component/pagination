{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "node",
    "baseUrl": "./",
    "jsx": "react",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["src/*"],
      "@@/*": [".dumi/tmp/*"],
      "@rc-component/pagination": ["src/index.ts"]
    },
    "ignoreDeprecations": "5.0"
  },
  "include": [".dumirc.ts", ".fatherrc.ts", "src", "docs", "tests"],
  "exclude": ["node_modules", "lib", "es", "dist", "docs-dist", ".dumi"]
}
